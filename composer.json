{
    "name": "prikotov/moex-core",
    "description": "CLI tool for MOEX ISS API - Moscow Exchange market data",
    "type": "library",
    "license": "MIT",
    "keywords": ["moex", "moscow exchange", "api", "cli", "console", "stocks", "bonds", "securities"],
    "authors": [
        {
            "name": "Dmitry Prikotov",
            "email": "prikotov@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Moex\\Skill\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Moex\\Skill\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.8",
        "monolog/monolog": "^3.5",
        "psr/log": "^3.0",
        "symfony/config": "^8.0",
        "symfony/console": "^6.4|^7.0",
        "symfony/dependency-injection": "^6.4|^7.0",
        "symfony/dotenv": "^6.4|^7.0",
        "symfony/yaml": "^6.4|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10",
        "vimeo/psalm": "^5.0|^6.0"
    },
    "bin": [
        "bin/moex"
    ],
    "config": {
        "sort-packages": true,
        "platform-check": true
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "phpcs --standard=PSR12 src tests",
        "cs-fix": "phpcbf --standard=PSR12 src tests",
        "stan": "phpstan analyse",
        "psalm": "psalm"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        }
    }
}
